# Optional local paths for engine-assisted dataset construction.
# Do not put private API keys, SSH keys, passwords, or tokens in committed files.

# Chess bestmove
STOCKFISH_ENGINE=/absolute/path/to/stockfish

# Xiangqi bestmove
PIKAFISH_ENGINE=/absolute/path/to/pikafish
PIKAFISH_NET=/absolute/path/to/pikafish.nnue

# Go strong supervision
KATAGO_ENGINE=/absolute/path/to/katago
KATAGO_MODEL=/absolute/path/to/kata1-model.bin.gz
KATAGO_CONFIG=/absolute/path/to/analysis_example.cfg

# Optional HTTP User-Agent for public dataset download scripts.
DATASET_USER_AGENT=Mozilla/5.0

